    const grid = document.getElementById("galleryGrid");
    grid.innerHTML = "";

    if (!allPhotos.length) {
      grid.innerHTML = '<p class="gallery-empty">写真がまだありません。<br>「📓 作業を記録」から写真を追加できます。</p>';
      return;
    }
    if (!filtered.length) {
      grid.innerHTML = '<p class="gallery-empty">この果樹の写真はありません。</p>';
      return;
    }

    filtered.forEach(p => {
      const card = document.createElement("div");
      card.className = "gallery-card";

      const img = document.createElement("img");
      img.className = "gallery-thumb";
      img.src = p.photo;
      img.alt = p.plantName;
      img.onclick = () => {
        document.getElementById("photoFull").src = p.photo;
        document.getElementById("photoOverlay").classList.add("open");
