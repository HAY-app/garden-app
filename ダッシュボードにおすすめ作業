  // 品種名クリックで編集フォームを開く
  function openVarietyEdit(id) {
    const v = loadVarieties().find(v => v.id === id);
    if (!v) return;
    activeVarietyEditId = id;

    document.getElementById("mFruitName").value   = v.fruitName || "";
    document.getElementById("mVarietyName").value = v.name;
    document.getElementById("mMemo").value        = v.memo || "";

    buildMonthPicker("mPruningPicker",     v.pruningTime     || []);
    buildMonthPicker("mFertilizingPicker", v.fertilizingTime || []);
    buildMonthPicker("mBloomPicker",       v.bloomTime       || []);
    buildMonthPicker("mHarvestPicker",     v.harvestTime     || []);
    buildMonthPicker("mRepotPicker",       v.repotTime       || []);

    document.getElementById("varietyFormTitle").textContent   = "✏️ 品種を編集";
    document.getElementById("varietyFormSaveBtn").textContent = "保存する";
    document.getElementById("varietyError").style.display     = "none";
    document.getElementById("varietyFormSection").scrollIntoView({ behavior: "smooth" });
  }

  // フォームを追加モードにリセット
  function resetVarietyForm() {
    activeVarietyEditId = null;
    ["mFruitName","mVarietyName","mMemo"].forEach(id => document.getElementById(id).value = "");
    buildMonthPicker("mPruningPicker");
    buildMonthPicker("mFertilizingPicker");
    buildMonthPicker("mBloomPicker");
    buildMonthPicker("mHarvestPicker");
    buildMonthPicker("mRepotPicker");
    document.getElementById("varietyFormTitle").textContent   = "＋ 品種を追加";
    document.getElementById("varietyFormSaveBtn").textContent = "追加する";
    document.getElementById("varietyError").style.display     = "none";
  }

  // キャンセル：編集中はリセット、追加中は閉じる
  function cancelVarietyForm() {
    if (activeVarietyEditId) resetVarietyForm();
    else                     closeVarietyModal();
  }

  // 追加・編集の共通保存処理
  function saveVarietyForm() {
    const fruitName = document.getElementById("mFruitName").value.trim();
    const name      = document.getElementById("mVarietyName").value.trim();
    if (!fruitName || !name) {
      document.getElementById("varietyError").style.display = "block";
      return;
    }
    document.getElementById("varietyError").style.display = "none";

    const entry = {
      fruitName,
      name,
      memo:            document.getElementById("mMemo").value.trim(),
      pruningTime:     getSelectedMonths("mPruningPicker"),
      fertilizingTime: getSelectedMonths("mFertilizingPicker"),
      bloomTime:       getSelectedMonths("mBloomPicker"),
      harvestTime:     getSelectedMonths("mHarvestPicker"),
      repotTime:       getSelectedMonths("mRepotPicker"),
    };

    const varieties = loadVarieties();
    if (activeVarietyEditId) {
      const idx = varieties.findIndex(v => v.id === activeVarietyEditId);
      if (idx !== -1) varieties[idx] = { ...varieties[idx], ...entry };
    } else {
      const newId = varieties.length ? Math.max(...varieties.map(v => v.id)) + 1 : 1;
      varieties.push({ id: newId, ...entry, createdAt: todayStr() });
    }

    saveVarieties(varieties);
    renderVarietyList();
    resetVarietyForm();
    render();
  }

  function deleteVariety(id) {
    if (!confirm("この品種をマスタから削除しますか？\n紐づいている果樹の品種リンクも解除されます。")) return;
    saveVarieties(loadVarieties().filter(v => v.id !== id));
    const plants = loadPlants();
    plants.forEach(p => { if (p.varietyId === id) p.varietyId = null; });
    savePlants(plants);
    renderVarietyList();
    render();
  }

  // 12か月のボタンを生成する
  function buildMonthPicker(containerId, selectedMonths = []) {
    const container = document.getElementById(containerId);
    container.innerHTML = "";
    for (let m = 1; m <= 12; m++) {
      const btn = document.createElement("button");
      btn.type          = "button";
      btn.dataset.month = m;
      btn.className     = "month-btn" + (selectedMonths.includes(m) ? " selected" : "");
      btn.textContent   = `${m}月`;
      btn.onclick       = () => btn.classList.toggle("selected");
      container.appendChild(btn);
    }
  }

  // 月ピッカーから選択中の月番号を配列で返す
  function getSelectedMonths(containerId) {
    return Array.from(document.getElementById(containerId).querySelectorAll(".month-btn.selected"))
      .map(btn => parseInt(btn.dataset.month))
      .sort((a, b) => a - b);
  }

  // 品種エントリを新規作成してIDを返す（内部共通処理）
  function createVarietyEntry(fruitName, name, memo = "") {
    const varieties = loadVarieties();
    const newId = varieties.length ? Math.max(...varieties.map(v => v.id)) + 1 : 1;
    varieties.push({
      id:              newId,
      name,
      fruitName,
      memo,
      pruningTime:     [],   // 剪定時期:    月番号の配列 例) [2, 3]
      fertilizingTime: [],   // 施肥時期:    月番号の配列 例) [3, 6, 9]
      harvestTime:     [],   // 収穫期:      月番号の配列 例) [6, 7, 8]
      bloomTime:       [],   // 開花期:      月番号の配列 例) [4, 5]
      repotTime:       [],   // 植え替え時期: 月番号の配列 例) [3, 10]
      createdAt:       todayStr()
    });
    saveVarieties(varieties);
    return newId;
  }

  // セレクトボックスを品種マスタで埋める
  function populateVarietySelect(selectId, currentVarietyId = null) {
    const sel = document.getElementById(selectId);
    const varieties = loadVarieties();
    sel.innerHTML = '<option value="">-- 選択しない --</option>';
    varieties.forEach(v => {
      const opt = document.createElement("option");
      opt.value = v.id;
      opt.textContent = v.fruitName ? `${v.fruitName} / ${v.name}` : v.name;
      if (v.id === currentVarietyId) opt.selected = true;
      sel.appendChild(opt);
    });
    const newOpt = document.createElement("option");
    newOpt.value = "__new__";
    newOpt.textContent = "＋ 新しい品種を追加";
    sel.appendChild(newOpt);
  }

  // "＋ 新しい品種を追加" 選択時にインライン入力欄を表示/非表示
  function handleVarietySelectChange(selectId, wrapId) {
    const val = document.getElementById(selectId).value;
    document.getElementById(wrapId).style.display = val === "__new__" ? "block" : "none";
  }

  /* ════════════ ダッシュボード ════════════ */

  function renderDashboard() {
    const plants   = loadPlants();
    const thisYear = new Date().getFullYear();

    let harvestCount = 0;
    let photoCount   = 0;
    let workCount    = 0;

    // 果樹ごとに今年の収穫量を集計
    const plantRanking = plants.map(plant => {
      workCount += (plant.fertilizeHistory?.length ?? 0)
                 + (plant.workHistory?.length ?? 0);
      photoCount += (plant.workHistory  || []).filter(e => e.photo).length;
      photoCount += (plant.photoHistory || []).length;

      let g = 0, ko = 0, count = 0;
      (plant.workHistory || [])
        .filter(e => e.type === "収穫" && new Date(e.date).getFullYear() === thisYear)
        .forEach(e => {
          count++;
          harvestCount++;
          if (e.quantity > 0) {
            if ((e.unit || "g") === "g") g  += e.quantity;
            else                          ko += e.quantity;
          }
        });
      return { plant, g, ko, count };
    })
    .filter(r => r.count > 0)
    .sort((a, b) => (b.g - a.g) || (b.ko - a.ko));

    const fmtNum = v => Number.isInteger(v) ? v : v.toFixed(1);

    // ランキング行を生成
    let rankingHtml;
    if (plantRanking.length === 0) {
      rankingHtml = `<div class="dash-rank-empty">まだ記録がありません</div>`;
    } else {
      rankingHtml = plantRanking.map((r, i) => {
        const varName = getVarietyDisplayName(r.plant);
        const nameStr = varName ? `${r.plant.name}・${varName}` : r.plant.name;
        const amounts = [];
        if (r.g  > 0) amounts.push(`${fmtNum(r.g)}g`);
        if (r.ko > 0) amounts.push(`${fmtNum(r.ko)}個`);
        const valStr = amounts.length ? amounts.join('・') : '数量未記録';
        return `
          <div class="dash-rank-row">
            <span class="dash-rank-num">${i + 1}</span>
            <span class="dash-rank-icon">${r.plant.icon}</span>
            <span class="dash-rank-name">${nameStr}</span>
            <span class="dash-rank-val">${valStr}</span>
          </div>`;
      }).join('');
    }

    // おすすめ作業の計算
    const varieties    = loadVarieties();
    const thisMonth    = getThisMonth();
    const nextMonth    = getNextMonth();
    const nextYear     = nextMonth === 1 ? thisYear + 1 : thisYear;
    const thisTasks    = getRecommendedTasks(plants, varieties, thisMonth, thisYear);
    const nextTasks    = getRecommendedTasks(plants, varieties, nextMonth, nextYear);
    const buildTaskRow = t => {
      const nm     = t.variety.name;
      const ps     = `${t.plant.icon} ${t.plant.name}${nm ? '・' + nm : ''}`;
      const cls    = t.done ? ' done' : ' clickable';
      const chk    = t.done ? '✅' : '○';
      const action = t.done ? '' :
        t.label === '施肥'
          ? `onclick="openRecordModal(${t.plant.id})"`
          : `onclick="openWorkModal(${t.plant.id}, '${t.label}')"`;
      return `<div class="dash-task-row${cls}" ${action}><span class="dash-task-check">${chk}</span><span>${t.icon} ${t.label}</span><span class="dash-task-plant">${ps}</span></div>`;
    };
    const thisTasksHtml = thisTasks.length
      ? thisTasks.map(buildTaskRow).join('')
      : '<div class="dash-tasks-empty">今月のおすすめ作業はありません</div>';
    const nextTasksHtml = nextTasks.length
      ? nextTasks.map(buildTaskRow).join('')
      : '<div class="dash-tasks-empty">来月のおすすめ作業はありません</div>';

    document.getElementById("dashboard").innerHTML = `
      <div class="dash-card">
        <div class="dash-icon">🌿</div>
        <div class="dash-value">${plants.length}<span class="dash-unit"> 種</span></div>
        <div class="dash-label">登録果樹数</div>
      </div>
      <div class="dash-card">
        <div class="dash-icon">📷</div>
        <div class="dash-value">${photoCount}<span class="dash-unit"> 枚</span></div>
        <div class="dash-label">写真枚数</div>
      </div>
      <div class="dash-card">
        <div class="dash-icon">📓</div>
        <div class="dash-value">${workCount}<span class="dash-unit"> 件</span></div>
        <div class="dash-label">作業履歴件数</div>
      </div>
      <div class="dash-card">
        <div class="dash-icon">🧺</div>
        <div class="dash-value">${harvestCount}<span class="dash-unit"> 回</span></div>
        <div class="dash-label">今年の収穫回数</div>
      </div>
      <div class="dash-card wide">
        <div class="dash-card-title">📊 今年の収穫量ランキング</div>
        <div class="dash-ranking">${rankingHtml}</div>
      </div>
      <div class="dash-card wide">
        <div class="dash-card-title">📌 おすすめ作業</div>
        <div class="dash-tasks">
          <div class="dash-task-section">
            <div class="dash-task-section-title">今月（${thisMonth}月）</div>
            ${thisTasksHtml}
          </div>
          <hr class="dash-task-divider">
          <div class="dash-task-section">
            <div class="dash-task-section-title">来月（${nextMonth}月）</div>
            ${nextTasksHtml}
          </div>
        </div>
      </div>
    `;
  }

  /* ════════════ 描画 ════════════ */

  function render() {
    renderDashboard();
    const plants = loadPlants();
    const list   = document.getElementById("plantList");
    list.innerHTML = "";

    if (!plants.length) {
      list.innerHTML = '<p class="empty-msg">果樹がまだ登録されていません。<br>「＋ 追加」から登録してください。</p>';
      return;
    }

    const varieties  = loadVarieties();
    const thisMonth  = getThisMonth();

    plants.forEach(plant => {
      const lastDate   = getLastFertilized(plant);
      const days       = daysSince(lastDate);
      const cls        = badgeClass(days);
      const daysText   = days !== null ? `${days}日経過` : "未記録";
      const totalCount = (plant.fertilizeHistory?.length ?? 0) + (plant.workHistory?.length ?? 0);

      // 品種マスタから剪定時期・追肥時期を取得
      const variety    = plant.varietyId ? varieties.find(v => v.id === plant.varietyId) : null;
      const seasonHtml = buildSeasonRow(variety, thisMonth);

      const card = document.createElement("div");
      card.className = "plant-card";
      card.setAttribute("draggable", "true");
      card.innerHTML = `
        <button class="delete-btn" onclick="deletePlant(${plant.id})" title="削除">✕</button>
        <div class="card-main">
          <div class="drag-handle" title="ドラッグして並び替え">⠿</div>
          <div class="plant-icon">${plant.icon}</div>
          <div class="plant-info">
            <div class="plant-name" onclick="openDetailModal(${plant.id})">${plant.name}</div>
            <div class="plant-sub">${getVarietyDisplayName(plant) || "品種未登録"}</div>
          </div>
          <div class="fertilize-block">
            <div class="fertilize-label">最後の施肥</div>
            <div class="fertilize-date">${formatDateShort(lastDate)}</div>
            <span class="days-badge ${cls}">${daysText}</span>
          </div>
        </div>
        ${seasonHtml}
        <div class="card-footer">
          <div class="footer-actions">
            <button class="btn-fertilize" onclick="openRecordModal(${plant.id})">🧪 施肥を記録</button>
            <button class="btn-work"      onclick="openWorkModal(${plant.id})">📓 作業を記録</button>
          </div>
          <button class="btn-history" onclick="openHistoryModal(${plant.id})">
            📋 履歴をみる（${totalCount}件）
          </button>
        </div>
      `;

      // ── ドラッグ＆ドロップ ──
      let canDrag = false;
      const handle = card.querySelector(".drag-handle");
      handle.addEventListener("mousedown", () => { canDrag = true; });
      handle.addEventListener("mouseup",   () => { canDrag = false; });

      card.addEventListener("dragstart", e => {
        if (!canDrag) { e.preventDefault(); return; }
        dragSourceId = plant.id;
        setTimeout(() => card.classList.add("dragging"), 0);
        e.dataTransfer.effectAllowed = "move";
      });
      card.addEventListener("dragend", () => {
        canDrag = false;
        card.classList.remove("dragging");
        document.querySelectorAll(".plant-card").forEach(c => c.classList.remove("drag-over"));
      });
      card.addEventListener("dragover", e => {
        e.preventDefault();
        if (dragSourceId !== null && plant.id !== dragSourceId) {
          card.classList.add("drag-over");
        }
      });
      card.addEventListener("dragleave", () => {
        card.classList.remove("drag-over");
      });
      card.addEventListener("drop", e => {
        e.preventDefault();
        card.classList.remove("drag-over");
        if (dragSourceId === null || dragSourceId === plant.id) return;
        const plants  = loadPlants();
        const fromIdx = plants.findIndex(p => p.id === dragSourceId);
        const toIdx   = plants.findIndex(p => p.id === plant.id);
        const [moved] = plants.splice(fromIdx, 1);
        plants.splice(toIdx, 0, moved);
        dragSourceId = null;
        savePlants(plants);
        render();
      });

      list.appendChild(card);
    });
  }

  function deletePlant(id) {
    const plants = loadPlants();
    const target = plants.find(p => p.id === id);
    if (!target || !confirm(`「${target.name}」を削除しますか？`)) return;
    savePlants(plants.filter(p => p.id !== id));
    render();
  }

  /* ════════════ ① 果樹追加 ════════════ */

  function buildIconPicker() {
    const picker = document.getElementById("iconPicker");
    picker.innerHTML = "";
    ICONS.forEach(icon => {
      const span = document.createElement("span");
      span.className = "icon-option" + (icon === selectedIcon ? " selected" : "");
      span.textContent = icon;
      span.onclick = () => {
        selectedIcon = icon;
        picker.querySelectorAll(".icon-option").forEach(el => el.classList.remove("selected"));
        span.classList.add("selected");
      };
      picker.appendChild(span);
    });
  }

  function openAddModal() {
    selectedIcon = "🌿";
    buildIconPicker();
    ["inputName","inputPlanted","inputNewFruitName","inputNewVarietyName"].forEach(id => document.getElementById(id).value = "");
    populateVarietySelect("inputVarietyId");
    document.getElementById("inputVarietyNewWrap").style.display = "none";
    document.getElementById("addErrorMsg").style.display = "none";
    document.getElementById("addOverlay").classList.add("open");
  }

  function closeAddModal() { document.getElementById("addOverlay").classList.remove("open"); }

  function saveNewPlant() {
    const name = document.getElementById("inputName").value.trim();
    if (!name) { document.getElementById("addErrorMsg").style.display = "block"; return; }

    const sel = document.getElementById("inputVarietyId").value;
    let varietyId = null;
    if (sel === "__new__") {
      const fruitName = document.getElementById("inputNewFruitName").value.trim();
      const varName   = document.getElementById("inputNewVarietyName").value.trim();
      if (varName) varietyId = createVarietyEntry(fruitName, varName);
    } else if (sel) {
      varietyId = parseInt(sel);
    }

    const plants = loadPlants();
    const newId  = plants.length ? Math.max(...plants.map(p => p.id)) + 1 : 1;
    plants.push({
      id:               newId,
      name,
      variety:          "",   // 新規登録は varietyId で管理
      varietyId,
      icon:             selectedIcon,
      plantedDate:      document.getElementById("inputPlanted").value,
      fertilizeHistory: [],
      workHistory:      []
    });
    savePlants(plants);
    closeAddModal();
    render();
  }

  /* ════════════ ② 施肥記録 ════════════ */

  function openRecordModal(id) {
    activeRecordId = id;
    const plant = loadPlants().find(p => p.id === id);
    document.getElementById("recordTitle").textContent = `🧪 施肥を記録 — ${plant.name}`;
    document.getElementById("recordDate").value = todayStr();
    document.getElementById("recordMemo").value = "";
    document.getElementById("recordOverlay").classList.add("open");
  }

  function closeRecordModal() {
    document.getElementById("recordOverlay").classList.remove("open");
    activeRecordId = null;
