    document.getElementById("photoRegInput").value               = "";
    document.getElementById("photoRegPreviewWrap").style.display = "none";
    document.getElementById("photoRegPreview").src               = "";
    document.getElementById("photoRegComment").value             = "";
  }

  function renderPhotoRegTagChips() {
    const row = document.getElementById("photoRegTagChips");
    row.innerHTML = "";
    photoRegTags.forEach((tag, i) => {
      const chip = document.createElement("span");
      chip.className = "tag-chip";
      chip.innerHTML = `${tag} <button onclick="removePhotoRegTag(${i})">✕</button>`;
      row.appendChild(chip);
    });
  }

  function addPhotoRegTag() {
    const input = document.getElementById("photoRegTagInput");
    const tag   = input.value.trim();
    if (!tag || photoRegTags.includes(tag)) { input.value = ""; return; }
    photoRegTags.push(tag);
    input.value = "";
    renderPhotoRegTagChips();
  }

  function removePhotoRegTag(idx) {
    photoRegTags.splice(idx, 1);
    renderPhotoRegTagChips();
  }

  function savePhotoReg() {
    const plantId = parseInt(document.getElementById("photoRegPlant").value);
    if (!plantId || !photoRegData) {
      document.getElementById("photoRegError").style.display = "block";
      return;
    }
    const entry = {
      date:         document.getElementById("photoRegDate").value || todayStr(),
      photo:        photoRegData,
      photoComment: document.getElementById("photoRegComment").value.trim() || undefined,
      tags:         photoRegTags.length ? [...photoRegTags] : undefined
    };
    const plants = loadPlants();
    const plant  = plants.find(p => p.id === plantId);
    if (!plant) return;
    plant.photoHistory.push(entry);
    savePlants(plants);
    closePhotoRegModal();
    renderGallery();
    renderDashboard();
  }

  /* ════════════ オーバーレイ外クリックで閉じる ════════════ */

  ["varietyOverlay","addOverlay","recordOverlay","workOverlay","detailOverlay","historyOverlay","galleryOverlay","photoRegOverlay"].forEach(id => {
    document.getElementById(id).addEventListener("click", function(e) {
      if (e.target === this) {
        this.classList.remove("open");
        activeRecordId = activeWorkId = activeHistoryId = null;
      }
    });
  });

  render();
</script>

</body>
</html>
