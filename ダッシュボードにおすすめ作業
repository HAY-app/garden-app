<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>果樹管理ノート</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Hiragino Sans", "Meiryo", sans-serif;
      background-color: #f4f8f0;
      color: #333;
    }

    /* ── ヘッダー ── */
    header {
      background-color: #4a7c59;
      color: white;
      padding: 20px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    header h1 { font-size: 22px; font-weight: bold; }
    header p  { font-size: 13px; margin-top: 4px; opacity: 0.8; }

    .add-btn {
      background: white;
      color: #4a7c59;
      border: none;
      border-radius: 8px;
      padding: 8px 16px;
      font-size: 14px;
      font-weight: bold;
      cursor: pointer;
      white-space: nowrap;
    }
    .add-btn:hover { background: #e8f5e1; }

    /* ── メイン ── */
    main {
      padding: 20px 16px;
      max-width: 600px;
      margin: 0 auto;
    }
    .section-title {
      font-size: 13px;
      color: #888;
      margin-bottom: 12px;
      letter-spacing: 0.05em;
    }

    /* ── ダッシュボード ── */
    .dashboard {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 20px;
    }
    .dash-card {
      background: white;
      border-radius: 12px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
      padding: 14px 16px;
    }
    .dash-card.wide { grid-column: 1 / -1; }
    .dash-icon { font-size: 18px; margin-bottom: 6px; }
    .dash-value {
      font-size: 22px;
      font-weight: bold;
      color: #2d5016;
      line-height: 1.2;
    }
    .dash-unit { font-size: 13px; font-weight: normal; color: #555; }
    .dash-label { font-size: 11px; color: #aaa; margin-top: 6px; }
    .dash-harvest-amounts { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
    .dash-harvest-sep { color: #ccc; font-size: 16px; }
    .dash-card-title { font-size: 12px; color: #888; margin-bottom: 10px; }
    .dash-ranking { display: flex; flex-direction: column; gap: 8px; }
    .dash-rank-row { display: flex; align-items: center; gap: 6px; font-size: 13px; }
    .dash-rank-num { font-size: 11px; color: #bbb; min-width: 14px; text-align: right; flex-shrink: 0; }
    .dash-rank-icon { font-size: 16px; line-height: 1; flex-shrink: 0; }
    .dash-rank-name { flex: 1; color: #444; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .dash-rank-val { font-weight: bold; color: #2d5016; white-space: nowrap; }
    .dash-rank-empty { color: #ccc; font-size: 13px; }
    .dash-tasks { display: flex; flex-direction: column; }
    .dash-task-section { margin-bottom: 4px; }
    .dash-task-section-title { font-size: 11px; color: #aaa; font-weight: bold; letter-spacing: 0.3px; margin-bottom: 6px; }
    .dash-task-row { display: flex; align-items: center; gap: 8px; font-size: 13px; padding: 4px 0; }
    .dash-task-row.done { opacity: 0.4; text-decoration: line-through; }
    .dash-task-row.clickable { cursor: pointer; border-radius: 6px; transition: background 0.15s; }
    .dash-task-row.clickable:hover { background: #f0f7ee; }
    .dash-task-check { font-size: 12px; width: 16px; text-align: center; flex-shrink: 0; color: #4a7c59; }
    .dash-task-plant { color: #888; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .dash-task-divider { border: none; border-top: 1px solid #f0f0f0; margin: 8px 0; }
    .dash-tasks-empty { color: #ccc; font-size: 13px; }

    /* ── 品種マスタ ── */
    .variety-item {
      display: flex;
      align-items: center;
      padding: 9px 4px;
      border-bottom: 1px solid #f0f0f0;
    }
    .variety-item:last-child { border-bottom: none; }
    .variety-item-info { flex: 1; }
    .variety-item-name { font-size: 14px; font-weight: bold; color: #333; }
    .variety-item-fruit { font-size: 11px; color: #aaa; margin-left: 8px; }
    .variety-del-btn {
      background: none; border: none; color: #ccc;
      cursor: pointer; font-size: 14px; padding: 4px 8px;
    }
    .variety-del-btn:hover { color: #e74c3c; }
    .variety-add-section {
      margin-top: 16px; padding-top: 16px;
      border-top: 1px solid #eee;
    }
    .variety-add-title { font-size: 13px; font-weight: bold; color: #555; margin-bottom: 10px; }
    .variety-legacy-note { font-size: 11px; color: #aaa; margin-top: 4px; }
    .variety-item-info { cursor: pointer; }
    .variety-item-info:hover .variety-item-name { text-decoration: underline; color: #3a7040; }
    .variety-season-badge { font-size: 10px; color: #4a7c59; background: #eaf3e4; border-radius: 4px; padding: 1px 5px; margin-left: 6px; }
    /* 月ピッカー */
    .month-picker { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 6px; }
    .month-btn {
      width: 38px; padding: 5px 0; text-align: center;
      border: 1px solid #ddd; border-radius: 6px;
      font-size: 11px; cursor: pointer; background: white; color: #666;
      user-select: none;
    }
    .month-btn.selected { background: #4a7c59; color: white; border-color: #4a7c59; font-weight: bold; }
    .month-btn:hover:not(.selected) { background: #f0f7f0; }
    .plant-list { display: flex; flex-direction: column; gap: 12px; }

    /* ── カード ── */
    .plant-card {
      background: white;
      border-radius: 12px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
      overflow: hidden;
      position: relative;
    }
    .card-main {
      padding: 16px 18px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .plant-icon { font-size: 36px; line-height: 1; flex-shrink: 0; }
    .plant-info { flex: 1; }
    .plant-name {
      font-size: 17px;
      font-weight: bold;
      color: #2d5016;
      cursor: pointer;
      display: inline-block;
    }
    .plant-name:hover { text-decoration: underline; color: #3a7040; }
    .plant-sub  { font-size: 12px; color: #888; margin-top: 2px; }
    .card-season-row {
      display: flex; gap: 10px; flex-wrap: wrap;
      padding: 6px 18px; border-top: 1px solid #f5f5f5;
      font-size: 11px; color: #aaa;
    }
    .season-item { display: flex; align-items: center; gap: 3px; }
    .season-item.in-season { color: #4a7c59; font-weight: bold; }
    .season-now-badge {
      font-size: 9px; background: #4a7c59; color: white;
      border-radius: 3px; padding: 1px 4px; margin-left: 2px;
    }

    .fertilize-block { text-align: right; flex-shrink: 0; }
    .fertilize-label { font-size: 11px; color: #aaa; }
    .fertilize-date  { font-size: 14px; font-weight: bold; color: #4a7c59; margin-top: 2px; }

    .days-badge {
      display: inline-block;
      margin-top: 4px;
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 99px;
      background-color: #eaf3e4;
      color: #4a7c59;
    }
    .days-badge.warn  { background-color: #fef3cd; color: #a07000; }
    .days-badge.alert { background-color: #fde8e8; color: #c0392b; }

    /* カードフッター: 2段構成 */
    .card-footer {
      border-top: 1px solid #f0f0f0;
      padding: 10px 14px;
      display: flex;
      flex-direction: column;
      gap: 7px;
    }
    .footer-actions { display: flex; gap: 8px; }

    .btn-fertilize {
      flex: 1;
      padding: 8px 6px;
      background: #4a7c59;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 13px;
      font-weight: bold;
      cursor: pointer;
    }
    .btn-fertilize:hover { background: #3a6347; }

    .btn-work {
      flex: 1;
      padding: 8px 6px;
      background: #f0f5ff;
      color: #3a5a9e;
      border: 1.5px solid #ccd8f5;
      border-radius: 8px;
      font-size: 13px;
      font-weight: bold;
      cursor: pointer;
    }
    .btn-work:hover { background: #dce8ff; }

    .btn-history {
      width: 100%;
      padding: 7px;
      background: #f5f5f5;
      color: #777;
      border: none;
      border-radius: 8px;
      font-size: 12px;
      cursor: pointer;
      text-align: center;
    }
    .btn-history:hover { background: #ebebeb; }

    .delete-btn {
      position: absolute;
      top: 10px;
      right: 12px;
      background: none;
      border: none;
      font-size: 16px;
      color: #ccc;
      cursor: pointer;
      padding: 2px 4px;
    }
    .delete-btn:hover { color: #e74c3c; }

    .drag-handle {
      color: #ccc;
      font-size: 20px;
      cursor: grab;
      flex-shrink: 0;
      padding: 0 6px 0 2px;
      user-select: none;
      line-height: 1;
    }
    .drag-handle:hover  { color: #999; }
    .drag-handle:active { cursor: grabbing; }
    .plant-card.dragging  { opacity: 0.35; }
    .plant-card.drag-over {
      outline: 2px dashed #4a7c59;
      outline-offset: -2px;
      background: #f6fdf6;
    }

    .empty-msg {
      text-align: center;
      color: #aaa;
      font-size: 14px;
      padding: 40px 0;
      line-height: 1.8;
    }

    /* ── モーダル共通 ── */
    .overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.45);
      z-index: 100;
      align-items: center;
      justify-content: center;
    }
    .overlay.open { display: flex; }

    .modal {
      background: white;
      border-radius: 16px;
      padding: 24px;
      width: 360px;
      max-width: 90vw;
      max-height: 88vh;
      overflow-y: auto;
      box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    }
    .modal h2 { font-size: 17px; color: #2d5016; margin-bottom: 18px; }

    .field { margin-bottom: 14px; }
    .field label { font-size: 12px; color: #666; display: block; margin-bottom: 4px; }
    .field input,
    .field textarea {
      width: 100%;
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 8px 10px;
      font-size: 14px;
      font-family: inherit;
      outline: none;
    }
    .field input:focus,
    .field textarea:focus { border-color: #4a7c59; }
    .field textarea { resize: vertical; min-height: 80px; }

    /* アイコン選択 */
    .icon-picker { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
    .icon-option {
      font-size: 24px;
      cursor: pointer;
      padding: 4px 6px;
      border-radius: 8px;
      border: 2px solid transparent;
    }
    .icon-option.selected { border-color: #4a7c59; background: #eaf3e4; }

    /* 作業種別ボタングリッド */
    .work-type-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 4px;
    }
    .type-btn {
      padding: 10px 4px;
      border: 2px solid #eee;
      border-radius: 10px;
      background: white;
      font-size: 13px;
      line-height: 1.5;
      text-align: center;
      cursor: pointer;
    }
    .type-btn:hover { border-color: #c5dfc9; background: #f6fdf6; }
    .type-btn.selected {
      border-color: #3a5a9e;
      background: #f0f5ff;
      color: #2a4080;
      font-weight: bold;
    }

    /* ボタン */
    .modal-actions { display: flex; gap: 10px; margin-top: 20px; }
    .btn-cancel {
      flex: 1;
      padding: 10px;
      border: 1px solid #ddd;
      border-radius: 8px;
      background: white;
      cursor: pointer;
      font-size: 14px;
    }
    .btn-cancel:hover { background: #f5f5f5; }
    .btn-save {
      flex: 2;
      padding: 10px;
      border: none;
      border-radius: 8px;
      background: #4a7c59;
      color: white;
      font-size: 14px;
      font-weight: bold;
      cursor: pointer;
    }
    .btn-save:hover { background: #3a6347; }
    .btn-save.blue { background: #3a5a9e; }
    .btn-save.blue:hover { background: #2a4a8e; }

    .error-msg { font-size: 12px; color: #e74c3c; margin-top: 6px; display: none; }

    /* ── 履歴リスト ── */
    .history-list { display: flex; flex-direction: column; gap: 10px; }

    .history-item {
      border: 1px solid #eee;
      border-radius: 10px;
      padding: 12px 14px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
    }

    .history-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 4px;
    }
    .history-date {
      font-size: 13px;
      font-weight: bold;
      color: #555;
    }
    .kind-badge {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 99px;
      white-space: nowrap;
    }
    .kind-badge.fertilize { background: #eaf3e4; color: #3a6a44; }
    .kind-badge.work      { background: #eef2ff; color: #3a5a9e; }

    .history-memo {
      font-size: 13px;
      color: #666;
      line-height: 1.5;
      word-break: break-all;
    }
    .history-del {
      background: none;
      border: none;
      color: #ccc;
      cursor: pointer;
      font-size: 14px;
      padding: 0 2px;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .history-del:hover { color: #e74c3c; }

    .history-empty {
      text-align: center;
      color: #aaa;
      font-size: 13px;
      padding: 24px 0;
    }

    .history-filter {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 14px;
    }
    .filter-chip {
      padding: 4px 12px;
      border-radius: 99px;
      border: 1.5px solid #ddd;
      background: white;
      font-size: 12px;
      cursor: pointer;
      color: #666;
    }
    .filter-chip:hover { border-color: #4a7c59; color: #4a7c59; }
    .filter-chip.selected {
      background: #4a7c59;
      border-color: #4a7c59;
      color: white;
    }

    /* ── 収穫量入力 ── */
    .harvest-input {
      display: flex;
      gap: 8px;
      align-items: center;
    }
    .harvest-input input { flex: 1; }
    .unit-toggle {
      display: flex;
      border: 1.5px solid #ddd;
      border-radius: 8px;
      overflow: hidden;
      flex-shrink: 0;
    }
    .unit-btn {
      padding: 8px 14px;
      border: none;
      background: white;
      font-size: 14px;
      cursor: pointer;
      color: #666;
    }
    .unit-btn + .unit-btn { border-left: 1px solid #ddd; }
    .unit-btn.selected { background: #3a5a9e; color: white; font-weight: bold; }

    /* ── 写真 ── */
    .photo-upload-label {
      display: block;
      padding: 10px;
      background: #f5f5f5;
      border: 1.5px dashed #ccc;
      border-radius: 8px;
      font-size: 13px;
      color: #666;
      text-align: center;
      cursor: pointer;
      margin-top: 4px;
    }
    .photo-upload-label:hover { background: #ebebeb; border-color: #aaa; }

    .photo-preview-wrap {
      margin-top: 8px;
      position: relative;
      display: none;
    }
    .photo-preview {
      width: 100%;
      max-height: 200px;
      object-fit: cover;
      border-radius: 8px;
      display: block;
    }
    .photo-clear-btn {
      position: absolute;
      top: 6px; right: 6px;
      background: rgba(0,0,0,0.5);
      color: white;
      border: none;
      border-radius: 99px;
      width: 26px; height: 26px;
      font-size: 13px;
      cursor: pointer;
    }
    .photo-comment-input {
      width: 100%;
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 8px 10px;
      font-size: 13px;
      font-family: inherit;
      outline: none;
      margin-top: 8px;
      box-sizing: border-box;
    }
    .photo-comment-input:focus { border-color: #4a7c59; }

    .field select {
      width: 100%;
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 8px 10px;
      font-size: 14px;
      font-family: inherit;
      outline: none;
      background: white;
      cursor: pointer;
    }
    .field select:focus { border-color: #4a7c59; }
    .photo-comment-text {
      font-size: 12px;
      color: #666;
      font-style: italic;
      margin-top: 4px;
    }

    .history-thumb {
      width: 100%;
      max-height: 180px;
      object-fit: cover;
      border-radius: 8px;
      margin-top: 8px;
      display: block;
      cursor: pointer;
    }
    .history-thumb:hover { opacity: 0.85; }

    /* ── タグ ── */
    .tag-input-wrap {
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 8px 10px;
      background: white;
      margin-top: 4px;
    }
    .tag-input-wrap:focus-within { border-color: #4a7c59; }
    .tag-chips-row {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 6px;
    }
    .tag-chips-row:empty { margin-bottom: 0; }
    .tag-chip {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 3px 10px;
      background: #eaf3e4;
      color: #2d5016;
      border-radius: 99px;
      font-size: 12px;
    }
    .tag-chip button {
      background: none;
      border: none;
      color: #5a9a6a;
      cursor: pointer;
      font-size: 11px;
      padding: 0;
      line-height: 1;
    }
    .tag-chip button:hover { color: #c0392b; }
    .tag-input-row {
      display: flex;
      gap: 6px;
    }
    .tag-input-row input {
      flex: 1;
      border: none;
      outline: none;
      font-size: 13px;
      font-family: inherit;
      padding: 2px 0;
      min-width: 0;
    }
    .tag-add-btn {
      padding: 4px 12px;
      background: #4a7c59;
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 12px;
      cursor: pointer;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .tag-add-btn:hover { background: #3a6347; }

    .history-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 6px;
    }
    .hist-tag {
      font-size: 11px;
      padding: 2px 8px;
      background: #eaf3e4;
      color: #2d5016;
      border-radius: 99px;
    }

    /* ── ギャラリーボタン（ヘッダー） ── */
    .gallery-btn {
      background: rgba(255,255,255,0.2);
      color: white;
      border: 1px solid rgba(255,255,255,0.4);
      border-radius: 8px;
      padding: 8px 12px;
      font-size: 16px;
      cursor: pointer;
    }
    .gallery-btn:hover { background: rgba(255,255,255,0.35); }

    /* ── ギャラリーモーダル ── */
    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
    }
    .modal-close-btn {
      background: none;
      border: none;
      font-size: 20px;
      color: #aaa;
      cursor: pointer;
      padding: 0 2px;
      line-height: 1;
    }
    .modal-close-btn:hover { color: #555; }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .gallery-card {
      border-radius: 10px;
      overflow: hidden;
      background: #fafafa;
      border: 1px solid #eee;
      cursor: pointer;
    }
    .gallery-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.12); }
    .gallery-thumb {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      display: block;
    }
    .gallery-info { padding: 8px 10px; }
    .gallery-plant { font-size: 13px; font-weight: bold; color: #2d5016; }
    .gallery-meta  { font-size: 11px; color: #888; margin-top: 2px; line-height: 1.5; }
    .gallery-tags  { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 4px; }
    .gallery-filter-section { margin-bottom: 10px; }
    .gallery-filter-label {
      font-size: 11px;
      color: #aaa;
      margin-bottom: 4px;
    }

    .gallery-empty {
      grid-column: 1 / -1;
      text-align: center;
      color: #aaa;
      font-size: 13px;
      padding: 32px 0;
      line-height: 1.8;
    }

    /* 写真フルスクリーン */
    #photoOverlay {
      background: rgba(0,0,0,0.85);
      cursor: zoom-out;
    }
    #photoOverlay img {
      max-width: 92vw;
      max-height: 92vh;
      border-radius: 10px;
      object-fit: contain;
    }

    /* ── 基礎情報モーダル ── */
    .detail-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 20px;
    }
    .detail-icon    { font-size: 44px; line-height: 1; flex-shrink: 0; }
    .detail-name    { font-size: 20px; font-weight: bold; color: #2d5016; }
    .detail-variety { font-size: 13px; color: #888; margin-top: 3px; }

    .detail-info-box {
      background: #f9fdf7;
      border: 1px solid #e0eed8;
      border-radius: 10px;
      padding: 4px 14px;
      margin-bottom: 16px;
    }
    .detail-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
    }
    .detail-row + .detail-row { border-top: 1px solid #eee; }
    .detail-label { font-size: 12px; color: #888; flex-shrink: 0; margin-right: 12px; }
    .detail-value { font-size: 14px; font-weight: bold; color: #333; text-align: right; }
    .detail-value.empty { color: #bbb; font-weight: normal; font-size: 13px; }

    .detail-note-section { margin-top: 4px; }
    .detail-note-title {
      font-size: 12px;
      color: #888;
      margin-bottom: 10px;
      padding-bottom: 6px;
      border-bottom: 1px solid #eee;
    }

    /* ── 収穫量グラフ ── */
    .harvest-chart-section {
      margin-top: 20px;
      padding-top: 16px;
      border-top: 1px solid #eee;
    }
    .chart-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }
    .chart-title { font-size: 13px; font-weight: bold; color: #2d5016; }

    /* 月/年・単位の切り替えボタン */
    .chart-toggle {
      display: flex;
      border: 1.5px solid #ddd;
      border-radius: 8px;
      overflow: hidden;
    }
    .chart-toggle-btn {
      padding: 3px 10px;
      border: none;
      background: white;
      font-size: 12px;
      cursor: pointer;
      color: #666;
    }
    .chart-toggle-btn + .chart-toggle-btn { border-left: 1px solid #ddd; }
    .chart-toggle-btn.selected { background: #4a7c59; color: white; font-weight: bold; }

    /* バーグラフ本体 */
    .bar-chart-wrap { overflow-x: auto; padding-bottom: 4px; }
    .bar-chart {
      display: flex;
      align-items: flex-end;
      gap: 6px;
      height: 150px;      /* グラフエリアの高さ */
      padding: 0 2px;
      min-width: min-content;
    }
    .bar-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 3px;
      min-width: 38px;
      flex: 1;
    }
    .bar-value {
      font-size: 10px;
      color: #4a7c59;
      font-weight: bold;
      white-space: nowrap;
      line-height: 1;
    }
    .bar-fill {
      width: 80%;
      max-width: 44px;
      background: linear-gradient(to top, #3a6347, #6aaa7a);
      border-radius: 4px 4px 0 0;
      min-height: 4px;
      transition: height 0.3s ease;
    }
    .bar-label {
      font-size: 10px;
      color: #888;
      text-align: center;
      line-height: 1.3;
      white-space: nowrap;
    }
    .chart-empty {
      text-align: center;
      color: #bbb;
      font-size: 13px;
      padding: 16px 0;
    }
  </style>
</head>
<body>

<header>
  <div>
