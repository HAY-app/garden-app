<script>
  /* ════════════ 定数 ════════════ */

  const ICONS = ["🍓","🌿","🍋","🍊","🍇","🍒","🥭","🍑","🍐","🍎","🫐","🥝"];

  const WORK_TYPES = [
    { label: "水やり",   icon: "💧" },
    { label: "剪定",     icon: "✂️" },
    { label: "農薬散布", icon: "🫙" },
    { label: "植え替え", icon: "🪴" },
    { label: "収穫",     icon: "🧺" },
    { label: "その他",   icon: "📝" }
  ];

  // おすすめ作業・通知・カレンダー表示で共用する作業種別定義
  const RECOMMENDED_TASK_TYPES = [
    { field: "pruningTime",     label: "剪定",    icon: "✂️",  history: "work"      },
    { field: "fertilizingTime", label: "施肥",    icon: "🧪",  history: "fertilize" },
    { field: "repotTime",       label: "植え替え", icon: "🪴",  history: "work"      },
  ];

  /* ════════════ 状態 ════════════ */

  let selectedIcon     = "🌿";
  let selectedWorkType = WORK_TYPES[0].label;
  let activeRecordId   = null;
  let activeWorkId     = null;
  let activeHistoryId     = null;
  let activeHistoryFilter = "all";
  let selectedUnit        = "g";
  let workPhotoData       = null;
  let workTags            = [];
  let galleryFilter       = "all";
  let galleryTagFilter    = "all";
  let photoRegData        = null;
  let photoRegTags        = [];
  let chartMode           = "month"; // "month" または "year"
  let detailChartUnit     = "g";     // "g" または "個"
  const historyPhotoCache = [];
  let dragSourceId        = null;
  let activeDetailId      = null;
  let activeVarietyEditId = null; // null=追加モード / 数字=編集モード

  /* ════════════ データ ════════════ */

  /* ── 品種マスタ ── */
  function loadVarieties() {
    const saved = localStorage.getItem("garden_varieties");
    if (!saved) return [];
    return JSON.parse(saved).map(v => {
      // 旧データ移行: 文字列 "" → 空配列 []
      ["pruningTime","fertilizingTime","harvestTime","bloomTime","repotTime"].forEach(field => {
        if (!Array.isArray(v[field])) v[field] = [];
      });
      return v;
    });
  }

  function saveVarieties(varieties) {
    localStorage.setItem("garden_varieties", JSON.stringify(varieties));
  }

  // 表示用品種名を返す（varietyId優先、なければvariety文字列）
  function getVarietyDisplayName(plant) {
    if (plant.varietyId) {
      const v = loadVarieties().find(v => v.id === plant.varietyId);
      if (v) return v.name;
    }
    return plant.variety || "";
  }

  const DEFAULT_PLANTS = [
    { id: 1, name: "いちご",      variety: "とちおとめ",      icon: "🍓",
      plantedDate: "2025-10-15",
      fertilizeHistory: [{ date: "2026-05-20", memo: "" }],
      workHistory: [] },
    { id: 2, name: "いちじく",    variety: "ブラウンターキー", icon: "🫐",
      plantedDate: "2023-04-01",
      fertilizeHistory: [{ date: "2026-04-10", memo: "" }],
      workHistory: [] },
    { id: 3, name: "フェイジョア", variety: "アポロ",          icon: "🌿",
      plantedDate: "2022-11-03",
      fertilizeHistory: [{ date: "2026-03-05", memo: "" }],
      workHistory: [] }
  ];

  function loadPlants() {
    const saved = localStorage.getItem("garden_plants");
    if (!saved) return DEFAULT_PLANTS;
    return JSON.parse(saved).map(p => {
      // 旧データ移行
      if (!p.fertilizeHistory) {
        p.fertilizeHistory = p.lastFertilized ? [{ date: p.lastFertilized, memo: "" }] : [];
        delete p.lastFertilized;
      }
      if (!p.workHistory)      p.workHistory = [];
      if (!("potSize"         in p)) p.potSize         = "";
      if (!p.photoHistory)           p.photoHistory    = [];
      if (!("varietyId" in p))       p.varietyId       = null;
      return p;
    });
  }

  function savePlants(plants) {
    localStorage.setItem("garden_plants", JSON.stringify(plants));
  }

  function getLastFertilized(plant) {
    if (!plant.fertilizeHistory?.length) return null;
    return [...plant.fertilizeHistory]
      .sort((a, b) => new Date(b.date) - new Date(a.date))[0].date;
  }

  function getCombinedHistory(plant) {
    const fertilize = (plant.fertilizeHistory || []).map(e => ({ ...e, kind: "fertilize" }));
    const work      = (plant.workHistory      || []).map(e => ({ ...e, kind: "work"      }));
    return [...fertilize, ...work].sort((a, b) => new Date(b.date) - new Date(a.date));
  }

  /* ════════════ ユーティリティ ════════════ */

  /* ── 月判定（おすすめ作業・通知・カレンダーで再利用） ── */

  // 今月の番号を返す（1〜12）
  function getThisMonth() {
    return new Date().getMonth() + 1;
  }

  // 来月の番号を返す（12の次は1に戻る）
  function getNextMonth() {
    const m = getThisMonth();
    return m === 12 ? 1 : m + 1;
  }

  // 指定した月が配列に含まれるか判定
  // 使い方: isInSeason([2, 3], 2) → true
  function isInSeason(monthArray, month) {
    return Array.isArray(monthArray) && monthArray.includes(month);
  }

  // 品種リストから「指定月が作業時期」の品種だけ返す
  // 使い方: getVarietiesInSeason(varieties, "harvestTime") → 今月収穫できる品種
  function getVarietiesInSeason(varieties, field, month = getThisMonth()) {
    return varieties.filter(v => isInSeason(v[field], month));
  }

  // 月番号の配列を日本語文字列に変換（表示用）
  // 使い方: formatMonths([2, 3]) → "2月・3月"
  function formatMonths(monthArray) {
    if (!Array.isArray(monthArray) || !monthArray.length) return "未設定";
    return [...monthArray].sort((a, b) => a - b).map(m => `${m}月`).join("・");
  }

  // 指定した月・年にその作業が完了済みか判定
  // 施肥は fertilizeHistory、それ以外は workHistory の type で判定
  function isTaskDoneThisMonth(plant, taskType, month, year) {
    if (taskType.history === "fertilize") {
      return (plant.fertilizeHistory || []).some(e => {
        const d = new Date(e.date);
        return d.getFullYear() === year && d.getMonth() + 1 === month;
      });
    }
    return (plant.workHistory || []).some(e => {
      const d = new Date(e.date);
      return d.getFullYear() === year && d.getMonth() + 1 === month && e.type === taskType.label;
    });
  }

  // 推奨作業を判定して返す（通知・カレンダー・年間予定でも再利用可能）
  // 戻り値: [{ plant, variety, label, icon, done }, ...]
  function getRecommendedTasks(plants, varieties, month, year) {
    const tasks = [];
    plants.forEach(plant => {
      if (!plant.varietyId) return;
      const variety = varieties.find(v => v.id === plant.varietyId);
      if (!variety) return;
      RECOMMENDED_TASK_TYPES.forEach(taskType => {
        if (!isInSeason(variety[taskType.field], month)) return;
        const done = isTaskDoneThisMonth(plant, taskType, month, year);
        tasks.push({ plant, variety, label: taskType.label, icon: taskType.icon, done });
      });
    });
    return tasks;
  }

  /* ── 日付ユーティリティ ── */

  function daysSince(dateStr) {
    if (!dateStr) return null;
    const today = new Date(); today.setHours(0,0,0,0);
    return Math.floor((today - new Date(dateStr)) / 86400000);
  }

  function formatDate(dateStr) {
    if (!dateStr) return "未記録";
    const d = new Date(dateStr);
    return `${d.getFullYear()}年${d.getMonth()+1}月${d.getDate()}日`;
  }

  function formatDateShort(dateStr) {
    if (!dateStr) return "未記録";
    const d = new Date(dateStr);
    return `${d.getMonth()+1}月${d.getDate()}日`;
  }

  function todayStr() { return new Date().toISOString().slice(0,10); }

  function badgeClass(days) {
    if (days === null) return "";
    if (days >= 60) return "alert";
    if (days >= 30) return "warn";
    return "";
  }

  function workTypeIcon(label) {
    return WORK_TYPES.find(t => t.label === label)?.icon ?? "📝";
  }

  // カード用の時期行HTMLを生成（品種マスタの剪定時期・追肥時期を表示）
  function buildSeasonRow(variety, thisMonth) {
    if (!variety) return "";
    const parts = [];

    if (variety.pruningTime?.length) {
      const active = isInSeason(variety.pruningTime, thisMonth);
      const badge  = active ? '<span class="season-now-badge">今月</span>' : "";
      parts.push(`<span class="season-item${active ? " in-season" : ""}">✂️ ${formatMonths(variety.pruningTime)}${badge}</span>`);
    }
    if (variety.fertilizingTime?.length) {
      const active = isInSeason(variety.fertilizingTime, thisMonth);
      const badge  = active ? '<span class="season-now-badge">今月</span>' : "";
      parts.push(`<span class="season-item${active ? " in-season" : ""}">🧪 ${formatMonths(variety.fertilizingTime)}${badge}</span>`);
    }

    return parts.length ? `<div class="card-season-row">${parts.join("")}</div>` : "";
  }

  /* ════════════ 品種マスタ ════════════ */

  function openVarietyModal() {
    renderVarietyList();
    resetVarietyForm();
    document.getElementById("varietyOverlay").classList.add("open");
  }

  function closeVarietyModal() {
    document.getElementById("varietyOverlay").classList.remove("open");
    activeVarietyEditId = null;
  }

  function renderVarietyList() {
    const varieties = loadVarieties();
    const list = document.getElementById("varietyList");
    if (!varieties.length) {
      list.innerHTML = '<p style="color:#bbb;font-size:13px;text-align:center;padding:12px 0">品種が登録されていません</p>';
      return;
    }
    list.innerHTML = "";
    varieties.forEach(v => {
      const hasSeasons = [v.pruningTime, v.fertilizingTime, v.bloomTime, v.harvestTime, v.repotTime]
        .some(a => Array.isArray(a) && a.length > 0);
      const item = document.createElement("div");
      item.className = "variety-item";
      item.innerHTML = `
        <div class="variety-item-info" onclick="openVarietyEdit(${v.id})">
          <span class="variety-item-name">${v.name}</span>
          ${v.fruitName ? `<span class="variety-item-fruit">${v.fruitName}</span>` : ""}
          ${hasSeasons  ? `<span class="variety-season-badge">時期あり</span>` : ""}
        </div>
        <button class="variety-del-btn" onclick="deleteVariety(${v.id})">✕</button>`;
      list.appendChild(item);
    });
