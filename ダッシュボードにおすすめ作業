  function renderHarvestChart() {
    const plant = loadPlants().find(p => p.id === activeDetailId);
    if (!plant) return;

    // 収穫記録（数量あり）だけ取り出す
    const records = (plant.workHistory || [])
      .filter(e => e.type === "収穫" && e.quantity > 0);

    // 使われている単位を調べる（g / 個 / 両方）
    const units       = [...new Set(records.map(e => e.unit || "g"))];
    const unitToggle  = document.getElementById("unitToggle");
    unitToggle.style.display = units.length > 1 ? "flex" : "none";

    // 現在選択中の単位にデータがなければ、実際に使われている単位に切り替える
    if (units.length > 0 && !units.includes(detailChartUnit)) {
      detailChartUnit = units[0];
      document.getElementById("toggleG").classList.toggle("selected",  detailChartUnit === "g");
      document.getElementById("toggle個").classList.toggle("selected", detailChartUnit === "個");
    }

    // 現在選択中の単位に絞る
    const filtered = records.filter(e => (e.unit || "g") === detailChartUnit);

    // 月ごと または 年ごとに数量を合計する
    const groups = {};
    filtered.forEach(entry => {
      const d   = new Date(entry.date);
      const key = chartMode === "month"
        ? `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`
        : `${d.getFullYear()}`;
      groups[key] = (groups[key] || 0) + entry.quantity;
    });

    // 日付順に並べる
    const data = Object.entries(groups).sort(([a], [b]) => a.localeCompare(b));

    const chartEl = document.getElementById("harvestChart");
    const emptyEl = document.getElementById("chartEmpty");
    chartEl.innerHTML = "";

    if (!data.length) {
      chartEl.style.display = "none";
      emptyEl.style.display = "block";
      return;
    }

    chartEl.style.display = "flex";
    emptyEl.style.display = "none";

    const maxVal    = Math.max(...data.map(([, v]) => v));
    const CHART_H   = 110; // バー最大高さ（px）
    const multiYear = new Set(data.map(([k]) => k.slice(0, 4))).size > 1;

    data.forEach(([key, val]) => {
      // バーの高さ = (この期間の量 ÷ 最大量) × グラフ最大高さ
      const barH = maxVal > 0 ? Math.max(4, Math.round((val / maxVal) * CHART_H)) : 4;

      // ラベルを作る
      let label;
      if (chartMode === "month") {
        const [y, m] = key.split("-");
        label = multiYear
          ? `${m}月<br><span style="font-size:9px;color:#aaa">${y}</span>`
          : `${m}月`;
      } else {
        label = `${key}年`;
      }

      const valDisplay = Number.isInteger(val) ? val : val.toFixed(1);

      const item = document.createElement("div");
      item.className = "bar-item";
      item.innerHTML = `
        <div class="bar-value">${valDisplay}${detailChartUnit}</div>
        <div class="bar-fill" style="height:${barH}px"></div>
        <div class="bar-label">${label}</div>
      `;
      chartEl.appendChild(item);
    });
  }

