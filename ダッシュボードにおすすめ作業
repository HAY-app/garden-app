    // 果樹フィルター（2種類以上の果樹に写真がある場合のみ表示）
    const plantFilterDiv = document.getElementById("galleryPlantFilter");
    plantFilterDiv.innerHTML = "";
    const plantIds = [...new Set(allPhotos.map(p => p.plantId))];
    if (plantIds.length > 1) {
      const label = document.createElement("div");
      label.className = "gallery-filter-label";
      label.textContent = "果樹";
      const items = [
        { key: "all", label: "すべて" },
        ...plantIds.map(id => {
          const pl = plants.find(p => p.id === id);
          return { key: id, label: pl ? `${pl.icon} ${pl.name}` : "" };
        })
      ];
      plantFilterDiv.appendChild(label);
      plantFilterDiv.appendChild(buildFilterRow(items, galleryFilter, setGalleryFilter));
    }

    // タグフィルター（タグがある場合のみ表示）
    const tagFilterDiv = document.getElementById("galleryTagFilter");
    tagFilterDiv.innerHTML = "";
    const allTags = [...new Set(allPhotos.flatMap(p => p.tags || []))];
    if (allTags.length > 0) {
      const label = document.createElement("div");
      label.className = "gallery-filter-label";
      label.textContent = "タグ";
      const items = [
        { key: "all", label: "すべて" },
        ...allTags.map(t => ({ key: t, label: t }))
      ];
      tagFilterDiv.appendChild(label);
      tagFilterDiv.appendChild(buildFilterRow(items, galleryTagFilter, setGalleryTagFilter));
    }

    // フィルター適用（果樹 AND タグ）
    const filtered = allPhotos.filter(p => {
      const matchPlant = galleryFilter    === "all" || p.plantId === galleryFilter;
      const matchTag   = galleryTagFilter === "all" || p.tags?.includes(galleryTagFilter);
      return matchPlant && matchTag;
